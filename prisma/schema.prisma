generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  fullName         String
  password         String
  verified         Boolean           @default(false)
  role             UserRole          @default(USER)
  phone            String
  provider         String?
  providerId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cart             Cart?
  order            Order?
  verificationCode VerificationCode?

  @@unique([id, email])
}

model Category {
  id        String    @id @unique @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String        @id @unique @default(uuid())
  name        String
  imageUrl    String
  phone       String?
  categoryId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productItem ProductItem[]
  ingredients Ingredient[]  @relation("IngredientToProduct")
}

model ProductItem {
  id        String    @id @unique @default(uuid())
  price     Int
  size      Int?
  pizzaType Int?
  productId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cartItem  CartItem?
  product   Product   @relation(fields: [productId], references: [id])
}

model Ingredient {
  id        String     @id @unique @default(uuid())
  name      String
  price     Int
  imageUrl  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cartItem  CartItem[] @relation("CartItemToIngredient")
  product   Product[]  @relation("IngredientToProduct")
}

model Cart {
  id          String     @id @unique @default(uuid())
  userId      String?    @unique
  token       String     @unique
  totalAmount Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User?      @relation(fields: [userId], references: [id])
  cartItem    CartItem[]
}

model CartItem {
  id            String       @id @unique @default(uuid())
  quantity      Int
  productItemId String       @unique
  cartId        String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  cart          Cart         @relation(fields: [cartId], references: [id])
  productItem   ProductItem  @relation(fields: [productItemId], references: [id])
  ingredients   Ingredient[] @relation("CartItemToIngredient")
}

model Order {
  id          String      @id @unique @default(uuid())
  userId      String?     @unique
  token       String
  status      OrderStatus @default(PENDING)
  paymentId   String?
  items       Json
  totalAmount Int         @default(0)
  fullName    String
  address     String
  email       String
  phone       String
  comment     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User?       @relation(fields: [userId], references: [id])
}

model VerificationCode {
  id        String   @id @unique @default(uuid())
  code      String   @unique
  userId    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum OrderStatus {
  PENDING
  SUCCESSED
  CANCELLED
}

enum UserRole {
  USER
  ADMIN
}
